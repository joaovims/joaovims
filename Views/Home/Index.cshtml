@model RetroagirNfEntrada.Models.BuscaNotaFiscalViewModel
@{
    ViewData["Title"] = "Retroação de Notas Fiscais";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-file-invoice"></i> Retroação de Notas Fiscais
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Formulário de Busca -->
                    <form id="formBusca" class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NumeroNfTransferencia" class="form-label"></label>
                            <input asp-for="NumeroNfTransferencia" class="form-control" placeholder="Digite o número da nota fiscal">
                            <span asp-validation-for="NumeroNfTransferencia" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Filial" class="form-label"></label>
                            <input asp-for="Filial" class="form-control" type="text" placeholder="Ex: Filial">
                            <span asp-validation-for="Filial" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FilialOrigem" class="form-label"></label>
                            <input asp-for="FilialOrigem" class="form-control" type="text" placeholder="Ex: Filial Origem">
                            <span asp-validation-for="FilialOrigem" class="text-danger"></span>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                        </div>
                    </form>

                    <hr>

                    <!-- Loading -->
                    <div id="loading" class="text-center d-none">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Carregando...</span>
                        </div>
                        <p class="mt-2">Buscando nota fiscal...</p>
                    </div>

                    <!-- Resultado da Busca -->
                    <div id="resultadoBusca" class="d-none">
                        <div class="alert alert-info">
                            <h5><i class="fas fa-info-circle"></i> Nota Fiscal Encontrada</h5>
                            <p class="mb-2">Confira os dados abaixo antes de prosseguir com a retroação:</p>
                        </div>

                        <div class="row">
                            <div class="col-lg-8">
                                <div class="table-responsive">
                                    <table class="table table-bordered">
                                        <tbody>
                                            <tr>
                                                <th width="30%">Número da Nota:</th>
                                                <td id="dadosNumeroNfTransferencia"></td>
                                            </tr>
                                            <tr>
                                                <th>Filial:</th>
                                                <td id="dadosFilial"></td>
                                            </tr>
                                            <tr>
                                                <th>Filial Origem:</th>
                                                <td id="dadosFilialOrigem"></td>
                                            </tr>
                                            <tr>
                                                <th>Data de Emissão Atual:</th>
                                                <td id="dadosEmissao"></td>
                                            </tr>
                                            <tr>
                                                <th>Data Entrada Conferida Atual:</th>
                                                <td id="dadosDataEntrada"></td>
                                            </tr>
                                            <tr>
                                                <th>Valor Total:</th>
                                                <td id="dadosValorTotal"></td>
                                            </tr>
                                            <tr>
                                                <th>Quantidade Total:</th>
                                                <td id="dadosQuantidadeTotal"></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="mt-3">
                                    <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#modalRetroacao">
                                        <i class="fas fa-clock"></i> Retroagir Nota
                                    </button>
                                    <button type="button" class="btn btn-secondary ms-2" onclick="limparResultado()">
                                        <i class="fas fa-times"></i> Nova Busca
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Mensagens de Erro -->
                    <div id="mensagemErro" class="alert alert-danger d-none"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Retroação -->
<div class="modal fade" id="modalRetroacao" tabindex="-1" aria-labelledby="modalRetroacao" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-clock"></i> Retroação de Nota Fiscal
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="formRetroacao">
                <div class="modal-body">
                    <input type="hidden" id="hdnNumeroNf" name="NumeroNfTransferencia">
                    <input type="hidden" id="hdnFilial" name="Filial">
                    <input type="hidden" id="hdnFilialOrigem" name="FilialOrigem">

                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Atenção:</strong> Esta ação irá alterar as datas da nota fiscal no banco de dados.
                    </div>

                    <div class="mb-3">
                        <label for="novaEmissao" class="form-label">Nova Data de Emissão</label>
                        <input type="date" class="form-control" id="novaEmissao" name="Emissao" required>
                    </div>

                    <div class="mb-3">
                        <label for="novaDataEntrada" class="form-label">Nova Data Entrada Conferida</label>
                        <input type="date" class="form-control" id="novaDataEntrada" name="DataEntradaConferida" required>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-warning" id="btnConfirmarRetroacao">
                        <i class="fas fa-clock"></i> Confirmar Retroação
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
